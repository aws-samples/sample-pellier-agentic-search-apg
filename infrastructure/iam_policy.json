{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockModelAccess",
      "Effect": "Allow",
      "Action": "bedrock:InvokeModel",
      "Resource": [
        "arn:aws:bedrock:us-west-2::foundation-model/global.anthropic.claude-opus-4-7",
        "arn:aws:bedrock:us-west-2::foundation-model/global.anthropic.claude-sonnet-4-6",
        "arn:aws:bedrock:us-west-2::foundation-model/global.anthropic.claude-haiku-4-5-20251001-v1:0",
        "arn:aws:bedrock:us-west-2::foundation-model/us.cohere.embed-v4:0",
        "arn:aws:bedrock:us-west-2::foundation-model/cohere.rerank-v3-5:0"
      ]
    },
    {
      "Sid": "BedrockInvokeModelStreaming",
      "Effect": "Allow",
      "Action": "bedrock:InvokeModelWithResponseStream",
      "Resource": [
        "arn:aws:bedrock:us-west-2::foundation-model/global.anthropic.claude-opus-4-7",
        "arn:aws:bedrock:us-west-2::foundation-model/global.anthropic.claude-sonnet-4-6",
        "arn:aws:bedrock:us-west-2::foundation-model/global.anthropic.claude-haiku-4-5-20251001-v1:0"
      ]
    },
    {
      "Sid": "AgentCoreAccess",
      "Effect": "Allow",
      "Action": [
        "bedrock-agentcore:CreateRuntime",
        "bedrock-agentcore:InvokeRuntime",
        "bedrock-agentcore:GetSession",
        "bedrock-agentcore:PutSessionMemory",
        "bedrock-agentcore:GetSessionMemory",
        "bedrock-agentcore:InvokeGateway",
        "bedrock-agentcore:GetIdentity"
      ],
      "Resource": "arn:aws:bedrock-agentcore:us-west-2:${AWS::AccountId}:runtime/pellier-*"
    },
    {
      "Sid": "AuroraDataAccess",
      "Effect": "Allow",
      "Action": ["rds-db:connect"],
      "Resource": "arn:aws:rds-db:us-west-2:${AWS::AccountId}:dbuser:${AuroraClusterResourceId}/pellier_app"
    },
    {
      "Sid": "CognitoAdminActionsForBootstrap",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:AdminCreateUser",
        "cognito-idp:AdminSetUserPassword",
        "cognito-idp:AdminAddUserToGroup",
        "cognito-idp:AdminInitiateAuth",
        "cognito-idp:AdminGetUser"
      ],
      "Resource": "arn:aws:cognito-idp:us-west-2:${AWS::AccountId}:userpool/${CognitoUserPoolId}"
    },
    {
      "Sid": "SecretsManagerRead",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": [
        "arn:aws:secretsmanager:us-west-2:${AWS::AccountId}:secret:pellier-db-secret-*",
        "arn:aws:secretsmanager:us-west-2:${AWS::AccountId}:secret:pellier/google-oauth-*",
        "arn:aws:secretsmanager:us-west-2:${AWS::AccountId}:secret:pellier/apple-oauth-*",
        "arn:aws:secretsmanager:us-west-2:${AWS::AccountId}:secret:pellier/cognito-test-users-*",
        "arn:aws:secretsmanager:us-west-2:${AWS::AccountId}:secret:pellier/cognito-client-secret-*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-west-2:${AWS::AccountId}:log-group:/aws/pellier/*"
    },
    {
      "Sid": "TranscribeStreamingAccess",
      "Effect": "Allow",
      "Action": "transcribe:StartStreamTranscription",
      "Resource": "*"
    }
  ]
}
