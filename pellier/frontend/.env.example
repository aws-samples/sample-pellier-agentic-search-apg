# ========================================
# API Configuration
# ========================================
# Base URL for the FastAPI backend. The storefront spec (Task 6.1) uses
# VITE_API_BASE_URL; older components still read VITE_API_URL. Set both
# to the same value until the legacy name is fully removed.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# ========================================
# AWS Configuration
# ========================================
VITE_AWS_REGION=us-west-2

# ========================================
# Feature Flags
# ========================================
VITE_ENABLE_LAB2=false
