# ========================================
# Database Configuration
# ========================================
DB_HOST=your-cluster.cluster-xxxxx.us-west-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-secure-password

# Database URL (alternative to individual params)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ========================================
# AWS Configuration
# ========================================
AWS_REGION=us-west-2

# Aurora Cluster ARN (for RDS Data API if needed)
DB_CLUSTER_ARN=arn:aws:rds:us-west-2:123456789012:cluster:pellier-cluster

# Secrets Manager (for credentials)
DB_SECRET_ARN=arn:aws:secretsmanager:us-west-2:123456789012:secret:pellier-db-secret

# ========================================
# Bedrock Model IDs
# ========================================
BEDROCK_EMBEDDING_MODEL=cohere.embed-v4:0
BEDROCK_RERANK_MODEL=cohere.rerank-v3-5:0
BEDROCK_CHAT_MODEL=global.anthropic.claude-opus-4-6-v1

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
# Single-process model: the built SPA + /api are served from the same
# origin (port 8000), so CORS is not strictly required for the
# workshop flow. Kept permissive for local dev-server flows (legacy
# Vite on :5173, or a separate :3000 dev proxy).
CORS_ORIGINS=["http://localhost:8000","http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO

# ========================================
# Cognito / AgentCore Identity (Module 3 Challenge 9)
# ========================================
# Provisioned by the workshop bootstrap script or the
# .claude/prompts/infrastructure.md playbook (Req 4.1.4).
# Fill these before starting the backend so /api/auth/* endpoints work.
COGNITO_POOL_ID=us-west-2_xxxxxxxxx
COGNITO_REGION=us-west-2
COGNITO_CLIENT_ID=your-cognito-app-client-id
COGNITO_CLIENT_SECRET=your-cognito-app-client-secret
COGNITO_DOMAIN=pellier.auth.us-west-2.amazoncognito.com

# Storefront origin + OAuth callback (Req 3.1.1, 3.1.2, 7.2.3).
# Single-process model: the SPA is served by FastAPI on :8000, so
# APP_BASE_URL and the OAuth callback share the same origin.
APP_BASE_URL=http://localhost:8000
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ========================================
# AgentCore Runtime, Memory, Gateway, Observability (Module 3)
# ========================================
# Provisioned by the workshop bootstrap script.
AGENTCORE_MEMORY_ID=
AGENTCORE_GATEWAY_URL=
AGENTCORE_GATEWAY_API_KEY=workshop
AGENTCORE_RUNTIME_ENDPOINT=

# Challenge 5 feature flag. Leave False to run the in-process Strands
# orchestrator (Challenge 4). Flip to True once C5 is complete to route
# /api/agent/chat through the managed AgentCore Runtime endpoint above.
USE_AGENTCORE_RUNTIME=false

# OpenTelemetry (Challenge 8)
OTEL_EXPORTER_OTLP_ENDPOINT=

# ========================================
# Bedrock Guardrails (Wire It Live / Lab 3)
# ========================================
# Guardrail resource to apply to agent input and output. Leave empty to
# run in pass-through mode (logs "guardrails disabled" at startup).
# Version defaults to DRAFT; set to a published version (e.g. "1") in prod.
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

